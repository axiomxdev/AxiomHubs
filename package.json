    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "imapflow": "^1.1.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.10",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0"
  },
