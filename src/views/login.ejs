<!doctype html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <title>Login — Axiom Hub's</title>
    <base href="/">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="/assets/axioms.ico">
    <meta name="description" content="Login to Axiom Hub's">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="login-section">
            <div class="login-container">
                <div class="login-card">
                    <h1 class="login-title">Welcome Back</h1>
                    <p class="login-description">
                        Sign in to access your Axiom Hub's account.
                    </p>

                    <!-- Login Form -->
                    <form id="login-form" class="login-form">
                        <div class="input-group">
                            <label for="email" class="input-label">Email</label>
                            <input type="email" id="email" name="email" class="login-input"
                                placeholder="Enter your email" required />
                        </div>

                        <div class="input-group">
                            <label for="password" class="input-label">Password</label>
                            <input type="password" id="password" name="password" class="login-input"
                                placeholder="Enter your password" required />
                        </div>

                        <button type="submit" class="login-btn login-btn-primary">
                            Sign In
                        </button>
                    </form>

                    <!-- Divider -->
                    <div class="login-divider">
                        <span class="divider-line"></span>
                        <span class="divider-text">OR</span>
                        <span class="divider-line"></span>
                    </div>

                    <!-- Discord Login -->
                    <a href="/login-discord" style="text-decoration: none; width: 100%;">
                        <button class="login-btn login-btn-discord" onclick="loginWithDiscord()">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"
                                style="vertical-align: middle; margin-right: 0.75rem;">
                                <path
                                    d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.096 2.157 2.42c0 1.333-.946 2.418-2.157 2.418z" />
                            </svg>
                            Continue with Discord
                        </button>
                    </a>

                    <!-- Additional Links -->
                    <div class="login-links">
                        <a href="/register" class="login-link">Don't have an account ? Sign up</a>
                        <a href="/forgot-password" class="login-link">Forgot password ?</a>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/cookies_popup') %>
                <script type="module" src="/js/login.js"></script>

</body>

</html>