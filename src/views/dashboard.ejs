<!doctype html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <title>Dashboard — Axiom Hub's</title>
    <base href="/">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/x-icon" href="/assets/axioms.ico">
    <meta name="description" content="Dashboard - Axiom Hub's">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="dashboard-section">
            <div class="dashboard-container">
                <div class="dashboard-card">
                    <h1 class="dashboard-title">Dashboard</h1>
                    <p class="dashboard-description">
                        Welcome to your Axiom Hub's dashboard. Here you can manage your account and access your API
                        key.
                    </p>

                    <div class="loading-container" id="loading">
                        <div class="loading-spinner"></div>
                        <p class="loading-text">Loading your data...</p>
                    </div>

                    <div class="dashboard-content" id="dashboard-content" style="display: none;">
                        <!-- User Information Card -->
                        <div class="info-card">
                            <div class="info-card-header">
                                <svg class="info-icon" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                                <h2 class="info-card-title">Account Information</h2>
                            </div>

                            <div class="info-group">
                                <label class="info-label">Email</label>
                                <div class="info-value" id="email">Loading...</div>
                            </div>

                            <div class="info-group">
                                <label class="info-label">Roblox Username</label>
                                <div class="info-value" id="roblox-username">Loading...</div>
                            </div>
                        </div>

                        <!-- API Key Card -->
                        <div class="info-card">
                            <div class="info-card-header">
                                <svg class="info-icon" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                    stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                                <h2 class="info-card-title">API Key</h2>
                            </div>

                            <div class="info-group">
                                <label class="info-label">Your Client Key</label>
                                <div class="api-key-container">
                                    <input type="password" class="api-key-input" id="api-key" readonly
                                        value="Loading...">
                                    <button class="api-key-toggle" id="toggle-key" title="Show/Hide API Key">
                                        <svg class="eye-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                        </svg>
                                    </button>
                                    <button class="api-key-copy" id="copy-key" title="Copy API Key">
                                        <svg class="copy-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                        </svg>
                                    </button>
                                </div>
                                <p class="info-hint">Keep your API key secure and never share it publicly.</p>
                            </div>
                        </div>

                        <!-- Logout Button -->
                        <button class="dashboard-btn dashboard-btn-logout" id="logout-btn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" style="margin-right: 0.5rem;">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            Logout
                        </button>
                    </div>

                    <div class="error-container" id="error-container" style="display: none;">
                        <div class="error-icon">⚠️</div>
                        <h2 class="error-title">Authentication Required</h2>
                        <p class="error-message" id="error-message">You need to be logged in to access the dashboard.
                        </p>
                        <a href="/login" class="dashboard-btn dashboard-btn-primary">Go to Login</a>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/cookies_popup') %>
                <script type="module" src="/js/dashboard.js"></script>

</body>

</html>