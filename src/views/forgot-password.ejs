<!doctype html>
<html lang="fr">

<head>
    <%- include('partials/head', { title: 'Forgot Password — Axiom Hub\' s', description: 'Reset your Axiom Hub\' s
        password', extraCSS: ['/css/login.css', '/css/forgot-password.css' ] }) %>
</head>

<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P73HFGSV" height="0" width="0"
            style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <%- include('partials/navbar') %>

        <main class="login-section">
            <div class="login-container">
                <div class="login-card">
                    <h1 class="login-title">Reset Password</h1>
                    <p class="login-description">
                        Enter your email address and we'll send you a link to reset your password.
                    </p>

                    <!-- Success Message -->
                    <div id="success-message" class="success-message">
                        ✓ Password reset link sent! Check your email.
                    </div>

                    <!-- Error Message -->
                    <div id="error-message" class="error-message">
                        ✗ Something went wrong. Please try again.
                    </div>

                    <!-- Forgot Password Form -->
                    <form id="forgot-password-form" class="login-form">
                        <div class="input-group">
                            <label for="email" class="input-label">Email</label>
                            <input type="email" id="email" name="email" class="login-input"
                                placeholder="Enter your email address" required />
                        </div>

                        <button type="submit" class="login-btn login-btn-primary">
                            Send Reset Link
                        </button>
                    </form>

                    <!-- Additional Links -->
                    <div class="login-links">
                        <a href="/login" class="login-link">
                            <span class="back-icon">←</span>
                            Back to Login
                        </a>
                        <a href="/register" class="login-link">Don't have an account ? Sign up</a>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/cookies_popup') %>
                <script src="/js/forgot-password.js"></script>

</body>

</html>